{
  "version": 1,
  "root_dir": "C:/Users/ericp/Github/epdev",
  "collectors": [
    {
      "name": "signal_count",
      "type": "manifest_signal_count",
      "thresholds": {}
    },
    {
      "name": "signal_velocity",
      "type": "manifest_signal_velocity",
      "window_days": 3,
      "thresholds": { "warn_below": 0.5, "crit_below": 0.1 },
      "isc_ref": "PRD-P4:ISC-3 Research outputs become signals or queued review artifacts"
    },
    {
      "name": "failure_count",
      "type": "file_count",
      "path": "memory/learning/failures",
      "ext": ".md",
      "thresholds": { "warn_above": 10, "crit_above": 20 },
      "min_delta": 3
    },
    {
      "name": "security_event_count",
      "type": "file_count",
      "path": "history/security",
      "ext": ".md",
      "thresholds": { "warn_above": 3, "crit_above": 10 },
      "min_delta": 3
    },
    {
      "name": "open_task_count",
      "type": "checkbox_count",
      "path": "orchestration/tasklist.md",
      "thresholds": { "warn_above": 80 }
    },
    {
      "name": "task_completion_velocity",
      "type": "checkbox_delta",
      "path": "orchestration/tasklist.md",
      "window_days": 7,
      "thresholds": {}
    },
    {
      "name": "isc_open",
      "type": "prd_checkbox",
      "prd_glob": "memory/work/*/PRD.md",
      "checkbox_state": "open",
      "thresholds": {}
    },
    {
      "name": "isc_met",
      "type": "prd_checkbox",
      "prd_glob": "memory/work/*/PRD.md",
      "checkbox_state": "met",
      "thresholds": {}
    },
    {
      "name": "isc_ratio",
      "type": "derived",
      "formula": "isc_met / (isc_met + isc_open)",
      "thresholds": { "warn_below": 0.3, "crit_below": 0.1 },
      "isc_ref": "PRD-P4:ISC-2 Heartbeat stores metric diff versus last baseline snapshot"
    },
    {
      "name": "sessions_per_day",
      "type": "query_events",
      "field": "sessions_per_day",
      "thresholds": { "warn_below": 0.5 }
    },
    {
      "name": "tool_failure_rate",
      "type": "query_events",
      "field": "failure_rate",
      "thresholds": { "warn_above": 0.05, "crit_above": 0.15 }
    },
    {
      "name": "top_tools",
      "type": "query_events",
      "field": "top_tools",
      "thresholds": {}
    },
    {
      "name": "learning_loop_health",
      "type": "file_recency",
      "path": "memory/learning/synthesis",
      "ext": ".md",
      "thresholds": { "warn_above": 14, "crit_above": 30 },
      "isc_ref": "PRD-P4:ISC-3 Research outputs become signals or queued review artifacts"
    },
    {
      "name": "steering_rules_recency",
      "type": "file_recency",
      "path": "CLAUDE.md",
      "thresholds": { "warn_above": 30, "crit_above": 60 }
    },
    {
      "name": "skill_count",
      "type": "dir_count",
      "path": ".claude/skills",
      "thresholds": {}
    },
    {
      "name": "repo_size",
      "type": "disk_usage",
      "path": ".",
      "thresholds": { "warn_above": 500, "crit_above": 1000 }
    },
    {
      "name": "events_dir_size",
      "type": "disk_usage",
      "path": "history/events",
      "thresholds": { "warn_above": 500, "crit_above": 1000 }
    },
    {
      "name": "memory_dir_size",
      "type": "disk_usage",
      "path": "memory",
      "thresholds": { "warn_above": 200, "crit_above": 500 }
    },
    {
      "name": "scheduled_tasks_unhealthy",
      "type": "scheduled_tasks",
      "task_folder": "\\Jarvis\\",
      "thresholds": { "warn_above": 1, "crit_above": 2 },
      "isc_ref": "PRD-P4:ISC-5 Background jobs close gap versus documented ideal state"
    },
    {
      "name": "cloud_audit_recency",
      "type": "file_recency",
      "path": "history/security",
      "ext": ".md",
      "thresholds": { "warn_above": 2, "crit_above": 3 },
      "isc_ref": "PRD-P4:ISC-5 Background jobs close gap versus documented ideal state"
    },
    {
      "name": "context_budget_proxy",
      "type": "hook_output_size",
      "hook_script": "tools/scripts/hook_session_start.py",
      "thresholds": { "warn_above": 3000, "crit_above": 5000 }
    },
    {
      "name": "auth_health",
      "type": "auth_health",
      "checks": ["slack"],
      "thresholds": { "crit_above": 1 },
      "isc_ref": "PRD-P4C:ISC Auth failures escalate to #general"
    },
    {
      "name": "producer_health",
      "type": "producer_health",
      "max_age_hours": 26,
      "thresholds": { "warn_above": 1, "crit_above": 3 },
      "isc_ref": "PRD-P4E:ISC-S3 producer_health alerts on stale/failed runs"
    },
    {
      "name": "autonomous_signal_rate",
      "type": "manifest_autonomous_signal_rate",
      "window_days": 7,
      "thresholds": { "warn_above": 10, "crit_above": 20 },
      "isc_ref": "PRD-P4E:ISC-S4 retention layer prevents unbounded growth"
    },
    {
      "name": "signal_volume",
      "type": "signal_volume",
      "thresholds": { "warn_above": 500, "crit_above": 1000 },
      "isc_ref": "PRD-P4E:ISC-S4 retention layer prevents unbounded growth"
    }
  ],
  "alert_routing": {
    "stdout": { "min_severity": "INFO" },
    "slack": { "min_severity": "WARN", "channel": "#epdev", "isc_ref": "PRD-P4:ISC-4 Slack posts follow channel severity rules" },
    "_ntfy_retired": "All notifications routed to Slack — 2026-03-27"
  },
  "retention": {
    "raw_days": 90,
    "rollup_after_days": 30,
    "gzip_after_days": 180
  },
  "snapshot_dir": "memory/work/isce",
  "signal_output_dir": "memory/learning/signals",
  "cooldown_minutes": 60,
  "remediation_map": {
    "signal_velocity": {
      "description": "Run /synthesize-signals to process accumulated learning signals",
      "skills": ["synthesize-signals"],
      "isc": [
        "New synthesis doc exists in memory/learning/synthesis/ | Verify: find memory/learning/synthesis -name '*.md' -newer orchestration/task_backlog.jsonl"
      ],
      "context_files": ["memory/learning/signals/"],
      "model": "opus",
      "min_severity": "WARN"
    },
    "learning_loop_health": {
      "description": "Run /synthesize-signals -- synthesis docs are stale",
      "skills": ["synthesize-signals"],
      "isc": [
        "New synthesis doc exists in memory/learning/synthesis/ | Verify: find memory/learning/synthesis -name '*.md' -newer orchestration/task_backlog.jsonl"
      ],
      "context_files": ["memory/learning/signals/"],
      "model": "opus",
      "min_severity": "WARN"
    },
    "cloud_audit_recency": {
      "description": "Run /security-audit to update security posture",
      "skills": ["security-audit"],
      "isc": [
        "Security audit report exists in history/security/ | Verify: find history/security -name '*audit*' -newer orchestration/task_backlog.jsonl"
      ],
      "context_files": ["security/constitutional-rules.md"],
      "model": "sonnet",
      "min_severity": "WARN"
    },
    "tool_failure_rate": {
      "description": "Review tool failure patterns and diagnose root cause",
      "skills": ["review-code"],
      "isc": [
        "Failure analysis doc exists | Verify: find memory/learning/failures -name '*.md' -newer orchestration/task_backlog.jsonl"
      ],
      "context_files": [],
      "model": "sonnet",
      "min_severity": "CRIT"
    }
  },
  "daily_alert_caps": {
    "slack": 20,
    "_ntfy_retired": 0,
    "_isc_ref": "PRD-P4:ISC-6 Slack notifier respects daily cap per channel"
  }
}
