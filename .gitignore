# Python
__pycache__/
*.py[cod]

# ------------------------------------------------------------------------------
# Secrets & credentials
# Aligns with security/constitutional-rules.md — never commit key material.
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
# SSH private keys (public keys like id_rsa.pub are not matched)
id_rsa
id_ed25519
id_ecdsa
# Broad filename patterns (exceptions below for repo-owned scanner/tests)
*credentials*
*secret*
!security/validators/secret_scanner.py
!tests/defensive/test_secret_scanner.py
# Network / VCS credential stores
.netrc
.git-credentials
# Cloud & IaC (common leak vectors)
*-service-account*.json
*-credentials.json
credentials.json
google-services.json
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# App token drops
.token
.token.*

# Local-only secret directories (some CLIs and backup tools)
.secrets/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Cursor — MCP and other local-only config (often contains API keys)
.cursor/mcp.json
.cursor/mcp.json.local

# Claude Code — machine-specific permissions; nested worktrees are not part of this repo
.claude/**/settings.local.json
.claude/worktrees/

# Node
node_modules/
bun.lock

# Temp
/tmp/
tmp/
*.tmp
*.bak

# Session memory (ephemeral, not committed)
memory/session/*
!memory/session/.gitkeep

# ------------------------------------------------------------------------------
# Personal memory content — blank-slate template only; users populate their own
# ------------------------------------------------------------------------------
# TELOS identity files (user fills these in on first setup)
memory/work/telos/*.md
!memory/work/telos/README.md
# Legacy flat TELOS files
memory/work/TELOS.md
memory/work/TELOS_CHALLENGES.md
memory/work/TELOS_GOALS.md
memory/work/TELOS_IDEAS.md
# Personal work documents and project state
memory/work/notion_brain.md
memory/work/slack-routing.md
memory/work/sources.md
# Personal project subdirectories (user creates their own)
memory/work/brain_map/
memory/work/byd_canada_ev/
memory/work/crypto_trading_bot/
memory/work/jarvis/
memory/work/jarvis_brain_map/
memory/work/observability/
memory/work/phase1-hooks-and-tests/
memory/work/slack_mobile_hub/
memory/work/emanuel_tools/
memory/work/isce/
memory/work/evolution-big-bang/
# Voice inbox content
memory/work/inbox/voice/*.md
memory/work/inbox/voice/processed/*.md
# Learning content (accumulated per user, not part of template)
memory/learning/signals/*.md
memory/learning/signals/processed/
memory/learning/failures/*.md
memory/learning/synthesis/*.md
memory/learning/_signal_meta.json

# ------------------------------------------------------------------------------
# Personal history content — blank-slate template only
# ------------------------------------------------------------------------------
history/decisions/*.md
history/changes/*.md
history/security/*.md
history/events/

# ------------------------------------------------------------------------------
# Runtime artifacts
# ------------------------------------------------------------------------------
.claude/prompt_ts.json
data/

# ------------------------------------------------------------------------------
# Fabric upstream patterns (large dependency, cloned locally — not part of repo)
# ------------------------------------------------------------------------------
tools/fabric-upstream/

# Large reference repos (cloned locally, not committed)
/refs/
.mcp.json
