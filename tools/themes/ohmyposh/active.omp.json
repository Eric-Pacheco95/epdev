{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} :: {{ .Folder }} [Cyberpunk]",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#000000",
          "background": "#FF2D78",
          "template": "  "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#000000",
          "background": "#00F5FF",
          "properties": {
            "style": "folder"
          },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#000000",
          "background": "#39FF14",
          "properties": {
            "fetch_status": true
          },
          "template": "  {{ .HEAD }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#000000",
          "background": "#FFD700",
          "properties": {
            "threshold": 500,
            "style": "austin"
          },
          "template": "  {{ .FormattedMs }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "exit",
          "style": "plain",
          "foreground": "#FF2D78",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#FF2D78{{ end }}"
          ],
          "template": "{{ if gt .Code 0 }}✗{{ else }}❯{{ end }} "
        }
      ]
    }
  ]
}